modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
REPORT_SEND_TIME = "20:00"
REPORT_DELIVERY_MODE = "database"
REVIEW_DELIVERY_MODE = "sms"
ROBIN_REPORT_WEBHOOK_URL = ""
GOOGLE_REVIEW_LINK = ""
FEEDBACK_FORM_URL = ""
REPORT_FALLBACK_EMAIL = ""
SUPABASE_DATABASE_URL = "postgresql://postgres.hclpovktywijfnswthpm:QoPTnehBzt4Oz5IB@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
